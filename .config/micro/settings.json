{
    "/home/ozh/.config/ozh/*": {
        "filetype": "shell"
    },
    "colorcolumn": 120,
    "colorscheme": "atom-dark",
    "diffgutter": true,
    "pluginrepos": [],
    "statusformatl": "$(modified)$(overwrite)$(filename):$(line),$(col) $(status.paste) | $(opt:encoding) $(opt:fileformat) | $(opt:filetype)",
    "statusformatr": "$(bind:ToggleKeyMenu): keys, $(bind:ToggleHelp): help",
    "tabstospaces": true
}
